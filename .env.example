# Секреты и порты — значения, которые задаёт пользователь при разворачивании.
# Скопируй в .env и поменяй пароли/секрет перед первым запуском.
#
# Порты вынесены сюда (не в config/app.env), потому что Docker Compose
# делает ${VAR}-подстановку в самом docker-compose.yml (ports: "${POSTGRES_PORT}:5432")
# только из корневого .env, а не из произвольных env_file. Порт БД — не секрет,
# но физически должен жить здесь, иначе подстановка в YAML не сработает.

POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=5173

POSTGRES_PASSWORD=change_me

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

JWT_SECRET_KEY=change_me_to_a_random_secret

# Telegram-алерты об ошибках (опционально, заготовка на будущее).
# Оставь пустыми — алерты будут просто логироваться (см. backend/app/core/alerts.py).
# Заполни, чтобы включить реальную отправку через Bot API:
# TELEGRAM_BOT_TOKEN=123456:AAExampleTokenFromBotFather
# TELEGRAM_CHAT_ID=123456789
