# Технические параметры с осмысленными дефолтами.
# Коммитится в репозиторий — секретов здесь нет.
# Меняешь значение один раз здесь — подхватывается везде, где используется имя переменной.

POSTGRES_HOST=db
POSTGRES_DB=element
POSTGRES_USER=element

# POSTGRES_PORT, BACKEND_PORT, FRONTEND_PORT — в .env (не здесь).
# Docker Compose делает ${VAR}-подстановку в самом docker-compose.yml
# (например, в маппинге "ports:") только из корневого .env,
# а не из произвольных env_file: — поэтому порты живут там,
# хотя секретами не являются. См. README (раздел «Конфигурация»).

LOG_LEVEL=info
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

CORS_ORIGINS=http://localhost:5173

# Максимальный размер загружаемого XML-фида, МБ
MAX_FEED_SIZE_MB=64
